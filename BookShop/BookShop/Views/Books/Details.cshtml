@model BookShop.EF.Tables.Book

@{
    ViewData["Title"] = "Book Details";
}

<h1>Book Details</h1>

<table class="table table-bordered">
    <tr>
        <th>Id</th>
        <td>@Model.Id</td>
    </tr>
    <tr>
        <th>Name</th>
        <td>@Model.Name</td>
    </tr>
    <tr>
        <th>ISBN</th>
        <td>@Model.Isbn</td>
    </tr>
    <tr>
        <th>Price</th>
        
        <td>@Model.Price.ToString("C", new System.Globalization.CultureInfo("bn-BD"))</td>
    </tr>
    <tr>
        <th>Author</th>
        <td>@Model.AuthorName</td>
    </tr>
</table>

<a asp-action="Update" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
<a asp-action="Index" class="btn btn-secondary">Back to List</a>