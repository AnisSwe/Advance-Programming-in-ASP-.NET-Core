@model IEnumerable<ProductInformation.Models.Product>

@{
    ViewData["Title"] = "Product List";
}

<h1>Product List</h1>

<table class="table">
    <thead>
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Price</th>
            <th>Category</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var product in Model)
        {
            <tr>
                <td>@product.Id</td>
                <td>
                    <!-- Link to Details page with route parameter -->
                    <a href="/Product/Details/@product.Id">@product.Name</a>

                    <!-- Alternative using Html Helper: -->
                    <!-- @Html.ActionLink(product.Name, "Details", new { id = product.Id }) -->
                    <!-- Alternative using Tag Helper: -->
                    <!-- <a asp-action="Details" asp-route-id="@product.Id">@product.Name</a> -->
                </td>
                <td>@product.Price.ToString("C")</td>
                <td>@product.Category</td>
            </tr>
        }
    </tbody>
</table>