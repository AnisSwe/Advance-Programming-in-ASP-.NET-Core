@{
    bool CheckGender(string gn)
    {

        if (Model.Gender != null && Model.Gender.Equals(gn))
        {

            return true;
        }
        return false;
    }
    bool CheckHobbiees(string hb)
    {

        if (Model.Hobbies != null)
        {

            foreach (var h in Model.Hobbies)
            {

                if (h.Equals(hb)) return true;
            }
        }
        return false;
    }

    bool CheckDepartment(string dp)
    {
        if(Model.Department != null && Model.Department.Equals(dp))
        {
            return true;

        }
        return false;
    }
}

@Html.ValidationSummary()
<form method="post">
    <input type="text" name="Email" value="@Model.Email" class="form-control" placeholder="Email" />
    Gender:
    <input type="radio" checked="@CheckGender("Male")" name="Gender" value="Male" />Male
    <input type="radio" checked="@CheckGender("Female")"  name="Gender" value="Female" />Female
    <br />
    Department:
    <select name="Department" class="form-control">
        <option value="" disabled="@(Model.Department == null ? "disabled" : null)" selected="@(Model.Department == null ? "selected" : null)">--Select--</option>

        <!-- Note: Added value="CS" and fixed the logic to check "CS" (uppercase) -->
        <option value="CS" selected="@(CheckDepartment("CS") ? "selected" : null)">CS</option>

        <option value="EEE" selected="@(CheckDepartment("EEE") ? "selected" : null)">EEE</option>

        <!-- Added logic for BBA as well -->
        <option value="BBA" selected="@(CheckDepartment("BBA") ? "selected" : null)">BBA</option>
    </select>
    <br />
    Hobbies:
    <input type="checkbox" checked="@CheckHobbiees("Cricket")" name="Hobbies[]" value="Cricket" /> Cricket
    <input type="checkbox" checked="@CheckHobbiees("Football")"  name="Hobbies[]" value="Football" /> Football
    <input type="checkbox" checked="@CheckHobbiees("Hockey")" name="Hobbies[]" value="Hockey" /> Hockey
    <input type="checkbox" checked="@CheckHobbiees("Badminton")" name="Hobbies[]" value="Badminton" /> Badminton
    <br />
    <input type="text" value="@Model.Roll" name="Roll" placeholder="Roll" class="form-control" />
    <input type="submit" value="Register" class="btn btn-success" />
</form>
