@model StudentProfile.Models.Student

@{
    ViewData["Title"] = "Student Profile";
}

<h2>Student Profile</h2>

<div class="card">
    <div class="card-body">
        <h4>@Model.Name</h4>
        <hr />

        <dl class="row">
            <dt class="col-sm-3">ID</dt>
            <dd class="col-sm-9">@Model.Id</dd>

            <dt class="col-sm-3">Name</dt>
            <dd class="col-sm-9">@Model.Name</dd>

            <dt class="col-sm-3">Age</dt>
            <dd class="col-sm-9">
                @Model.Age
                @if (Model.Age < 18)
                {
                    <span class="badge bg-warning">Minor</span>
                }
                else
                {
                    <span class="badge bg-success">Adult</span>
                }
            </dd>

            <dt class="col-sm-3">Department</dt>
            <dd class="col-sm-9">@Model.Department</dd>

            <dt class="col-sm-3">CGPA</dt>
            <dd class="col-sm-9">
                @Model.CGPA
                @if (Model.CGPA >= 3.5)
                {
                    <span class="badge bg-success">Excellent</span>
                }
                else
                {
                    <span class="badge bg-info">Average</span>
                }
            </dd>
        </dl>
    </div>
</div>