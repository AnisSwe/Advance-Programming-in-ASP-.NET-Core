@model BLL.DTO.BudgetDTO
@{
    ViewData["Title"] = "Add Budget";
}
<h4>Add Budget</h4>
<form method="post" style="max-width:400px">
    <div class="mb-3">
        <label>Category</label>
        <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select"><option value="">-- Select --</option></select>
    </div>
    <div class="mb-3"><label>Month (yyyy-MM)</label><input asp-for="MonthYear" class="form-control" placeholder="2026-05" /></div>
    <div class="mb-3"><label>Limit Amount (BDT)</label><input asp-for="LimitAmount" class="form-control" /></div>
    <button class="btn btn-success">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>