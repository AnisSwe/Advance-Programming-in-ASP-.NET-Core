@model BLL.DTO.BudgetDTO
@{
    ViewData["Title"] = "Edit Budget";
}
<h4>Edit Budget</h4>
<form method="post" style="max-width:400px">
    <input asp-for="BudgetId" type="hidden" />
    <div class="mb-3">
        <label>Category</label>
        <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select"></select>
    </div>
    <div class="mb-3"><label>Month (yyyy-MM)</label><input asp-for="MonthYear" class="form-control" /></div>
    <div class="mb-3"><label>Limit Amount (BDT)</label><input asp-for="LimitAmount" class="form-control" /></div>
    <button class="btn btn-warning">Update</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>