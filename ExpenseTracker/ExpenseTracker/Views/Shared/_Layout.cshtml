@using BLL.Services

@{
    var userName = Context.Session.GetString("UserName");
    var userId = Context.Session.GetInt32("UserId");
    int unreadCount = 0;
    if (userId != null)
    {
        var alertService = Context.RequestServices.GetService<AlertService>();
        unreadCount = alertService!.GetUnreadCount(userId.Value);
    }
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Expense Tracker</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark px-3">
        <a class="navbar-brand" href="#">💰 Expense Tracker</a>
        @if (userId != null)
        {
            <div class="navbar-nav ms-auto d-flex flex-row gap-2 align-items-center">
                <a class="nav-link text-white" asp-controller="Expense" asp-action="Index">Expenses</a>
                <a class="nav-link text-white" asp-controller="Expense" asp-action="Search">Search</a>
                <a class="nav-link text-white" asp-controller="Expense" asp-action="Recurring">Recurring</a>
                <a class="nav-link text-white" asp-controller="Expense" asp-action="Summary">Summary</a>
                <a class="nav-link text-white" asp-controller="Budget" asp-action="Index">Budgets</a>
                <a class="nav-link text-white" asp-controller="Budget" asp-action="Report">Report</a>

                <a class="nav-link text-white position-relative" asp-controller="Alert" asp-action="Index">
                    🔔
                    @if (unreadCount > 0)
                    {
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                            @unreadCount
                        </span>
                    }
                </a>

                <a class="nav-link text-warning" asp-controller="Account" asp-action="Logout">Logout (@userName)</a>
            </div>
        }
    </nav>
    <div class="container mt-4">
        @RenderBody()
    </div>
</body>
</html>