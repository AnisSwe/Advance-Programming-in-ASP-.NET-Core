@model List<BLL.DTO.ExpenseDTO>
@{
    ViewData["Title"] = "Search Expenses";
}
<h4>Search & Filter Expenses</h4>
<form method="get" class="row g-2 mb-4">
    <div class="col-md-3">
        <select name="categoryId" asp-items="ViewBag.Categories" class="form-select">
            <option value="">All Categories</option>
        </select>
    </div>
    <div class="col-md-2"><input type="date" name="from" class="form-control" placeholder="From" /></div>
    <div class="col-md-2"><input type="date" name="to" class="form-control" placeholder="To" /></div>
    <div class="col-md-2"><input type="number" name="maxAmount" class="form-control" placeholder="Max Amount" /></div>
    <div class="col-md-2"><button class="btn btn-primary w-100">Search</button></div>
</form>
@if (Model != null && Model.Any())
{
    <table class="table table-bordered">
        <thead class="table-dark"><tr><th>Date</th><th>Category</th><th>Description</th><th>Amount</th></tr></thead>
        <tbody>
            @foreach (var e in Model)
            {
                <tr><td>@e.Date</td><td>@e.CategoryName</td><td>@e.Description</td><td>@e.Amount BDT</td></tr>
            }
        </tbody>
    </table>
}
else if (Model != null)
{
    <p class="text-muted">No results found.</p>
}