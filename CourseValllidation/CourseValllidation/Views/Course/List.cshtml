@model List<CourseModel>

<h2>
    @(ViewBag.Semester != null ? $"Courses for {ViewBag.Semester}" : "All Courses")
</h2>

<!-- Filter buttons -->
<a href="/Course/List" class="btn btn-sm btn-outline-dark">All</a>
<a href="/Course/List/Fall-2024" class="btn btn-sm btn-outline-primary">Fall-2024</a>
<a href="/Course/List/Spring-2025" class="btn btn-sm btn-outline-success">Spring-2025</a>
<a href="/Course/Register" class="btn btn-sm btn-success float-end">+ Add Course</a>

<hr />

@if (Model.Count == 0)
{
    <p class="text-muted">No courses found.</p>
}
else
{
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>ID</th>
                <th>Code</th>
                <th>Title</th>
                <th>Credit</th>
                <th>Semester</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var course in Model)
            {
                <tr>
                    <td>@course.Id</td>
                    <td>@course.CourseCode</td>
                    <td>@course.Title</td>
                    <td>@course.Credit</td>
                    <td>@course.Semester</td>
                </tr>
            }
        </tbody>
    </table>
}